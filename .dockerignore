# Ignore everything by default, then re-include only the files required to
# install dependencies and build the server. This allow-list keeps the build
# context and the resulting image minimal, and prevents local or generated
# files from leaking in regardless of what exists in the working tree.
*

# Application source (test files are excluded again below)
!src/

# Dependency installation
!package.json
!pnpm-lock.yaml

# Build configuration
!tsconfig.json
!license-manager.config.cjs

# Build scripts (only the one used during the build)
!scripts/
scripts/*
!scripts/generate-build-constants.js

# License file copied into the final image
!LICENSE

# Exclude tests even though src/ is included
**/*.test.ts
**/__tests__/
